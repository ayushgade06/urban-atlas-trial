generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Buyer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  locality  String
  budget    String
  createdAt DateTime @default(now())
}

model Seller {
  id        String   @id @default(cuid())
  name      String
  phone     String
  locality  String
  plotSize  String
  price     String
  createdAt DateTime @default(now())
}

